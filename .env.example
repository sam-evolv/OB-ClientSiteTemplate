# OpenBook customer site template, environment variables
#
# Copy this file to .env.local for development.
# Never commit .env.local. Real keys live there only.
#
# Supabase project: OpenBook (id nrntaowmmemhjfxjqjch, region eu-west-1)

# Browser-safe URL of the Supabase project.
NEXT_PUBLIC_SUPABASE_URL=

# Browser-safe anon (publishable) key, RLS-restricted reads only.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Base URL for canonical links and the sitemap.
NEXT_PUBLIC_SITE_URL=https://openbook.ie

# Optional. The platform parent domain for subdomain-based tenant routing, e.g.
# "openbook.ie". When set, a published tenant with slug "x" is also served at
# x.<this-domain> (its platform subdomain), resolving to that tenant — so a
# single verified domain property can cover every tenant instead of per-business
# verification. Precedence is: custom domain first, then this subdomain, then the
# usual demo/404 fallback. The bare domain and www.<domain> are the marketing
# root, never a tenant. Leave unset to disable subdomain routing (host resolution
# then behaves exactly as before).
NEXT_PUBLIC_PLATFORM_DOMAIN=

# Optional, only needed if a business uses a Mapbox static map in location_fixed.
MAPBOX_TOKEN=

# Optional. Comma-separated extra hosts that should fall back to the demo
# business when no tenant maps to them (localhost and *.vercel.app are already
# treated as preview hosts). Real customer domains must NOT be listed here.
NEXT_PUBLIC_DEMO_FALLBACK_HOSTS=

# Optional. Google Maps Embed API key. When set, the fixed-location section
# renders an embedded map; when unset, it shows only a keyless directions link.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# Optional. Shared secret for POST /api/indexnow. When set, callers (the main
# OpenBook dashboard) must send it in the x-indexnow-secret header. The IndexNow
# key itself is public and lives in public/<key>.txt + lib/indexnow.ts.
INDEXNOW_SUBMIT_SECRET=
